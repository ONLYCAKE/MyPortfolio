{
  "version": 2,
  "env": {
    "CI": "false",
    "NODE_OPTIONS": "--openssl-legacy-provider"
  },
  "installCommand": "cd Portfolio-master && npm ci",
  "buildCommand": "cd Portfolio-master && npm run build",
  "outputDirectory": "Portfolio-master/build",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ]
}


